{
  "metadata": [
    {
      "src": [
        {
          "src": "../src",
          "files": [
            "**/*.csproj"
          ]
        }
      ],
      "dest": "api",
      "includePrivateMembers": false,
      "disableGitFeatures": false,
      "disableDefaultFilter": false,
      "noRestore": false,
      "namespaceLayout": "flattened",
      "memberLayout": "samePage",
      "allowCompilationErrors": false
    }
  ],
  "build": {
    "content": [
      {
        "files": [
          "**/*.{md,yml}"
        ],
        "exclude": [
          "_site/**",
          "obj/**"
        ]
      }
    ],
    "resource": [
      {
        "files": [
          "images/**",
          "public/**",
          "CNAME"
        ]
      }
    ],
    "output": "_site",
    "template": [
      "default",
      "modern"
    ],
    "globalMetadata": {
      "_appName": "BareWire",
      "_appTitle": "BareWire",
      "_enableSearch": true,
      "_appLogoPath": "images/logo.png",
      "_appFaviconPath": "images/favicon.png",
      "_appFooter": "<span>Built with <a href=\"https://dotnet.github.io/docfx\">DocFX</a> · © 2026 <a href=\"https://github.com/Wizard-Software\">Wizard-Software</a></span>",
      "_gitContribute": {
        "repo": "https://github.com/Wizard-Software/BareWire",
        "branch": "main"
      },
      "_gitUrlPattern": "github"
    },
    "sitemap": {
      "baseUrl": "https://barewire.wizardsoftware.pl/",
      "priority": 0.5,
      "changefreq": "weekly"
    },
    "xref": [],
    "xrefService": [
      "https://xref.docs.microsoft.com/query?uid={uid}"
    ],
    "markdownEngineName": "markdig",
    "postProcessors": [
      "ExtractSearchIndex"
    ],
    "keepFileLink": false,
    "disableGitFeatures": false
  }
}
